# NOTE: plaintext .env is GENERATED — never edit it directly and never commit it.
# It is built by `./scripts/secrets.sh decrypt <host>` from two encrypted files:
#   .env.sops              shared secrets (same on every server)
#   hosts/<host>.sops.env  per-server settings
# This example documents all variables for bootstrapping from scratch.

# ======== shared (.env.sops) ========

# Reusable, NON-EPHEMERAL Tailscale auth key. Only needed the first time a
# server joins the tailnet; can be blanked afterwards (state lives in /srv).
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
# Your tailnet's DNS name (Tailscale admin console -> DNS), e.g. tailxxxx.ts.net:
TS_TAILNET=your-tailnet.ts.net

CODE_SERVER_PASSWORD=change-me-to-a-long-random-string
# The SMB user is fixed as "jerry" in samba/compose.yml. Set its password here.
SMB_PASSWORD=change-me-too

# restic encryption passphrase — BACK IT UP; backups are unrecoverable without it.
RESTIC_PASSWORD=a-strong-passphrase-you-must-never-lose
# Backblaze B2 bucket + application key (Read & Write, scoped to the bucket).
B2_ACCOUNT_ID=your-b2-application-key-id
B2_ACCOUNT_KEY=your-b2-application-key
B2_BUCKET=your-bucket-name

# Read-only healthchecks.io API key for the homepage backup-status widget.
HC_API_KEY=your-readonly-api-key

# Optional second, local restic repo (e.g. an external drive). Empty to skip.
RESTIC_LOCAL_REPO=

# ======== per-server (hosts/<host>.sops.env) ========

# This server's tailnet hostname; all services live under
# https://<TS_HOSTNAME>.<TS_TAILNET>/ ( /code/ , /files/ , ... )
TS_HOSTNAME=myserver
# Path within the B2 bucket for THIS server's restic repo. Must be unique per
# server — two servers must never share a repo path.
RESTIC_B2_PATH=myserver
# healthchecks.io check for THIS server's backups (one check per server).
HC_PING_URL=https://hc-ping.com/your-check-uuid
HC_CHECK_UUID=your-check-uuid
