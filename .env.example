# NOTE: the canonical copy of this file is the encrypted .env.sops in git.
# Normally you never edit .env by hand — see "Secrets" in the README.
# This example documents the variables for bootstrapping from scratch.

# ---- Tailscale ----
# Generate an auth key at https://login.tailscale.com/admin/settings/keys
# Use a REUSABLE, NON-EPHEMERAL key (ideally tagged, e.g. tag:server): the same
# key is used by the gateway node and every per-service sidecar. After all
# nodes have joined, the key can be blanked here — state persists in /srv.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
# The name the gateway node shows up as on your tailnet:
TS_HOSTNAME=homeserver
# Your tailnet's DNS name (Tailscale admin console -> DNS), e.g. tailxxxx.ts.net:
TS_TAILNET=your-tailnet.ts.net

# ---- code-server ----
CODE_SERVER_PASSWORD=change-me-to-a-long-random-string

# ---- Samba ----
# The SMB user is fixed as "jerry" in samba/compose.yml. Set its password here.
SMB_PASSWORD=change-me-too

# ---- restic / Backblaze B2 ----
# Create a bucket and an application key in the B2 console.
RESTIC_PASSWORD=a-strong-passphrase-you-must-never-lose
B2_ACCOUNT_ID=your-b2-application-key-id
B2_ACCOUNT_KEY=your-b2-application-key
B2_BUCKET=your-bucket-name
# Path within the bucket for this host's repo:
RESTIC_B2_PATH=homeserver

# ---- Local restic repo (second, faster target; optional but recommended) ----
# Leave empty to skip the local repo. On the home PC, point this at an external drive.
RESTIC_LOCAL_REPO=
